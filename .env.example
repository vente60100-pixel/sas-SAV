# ============================================
# OKTAGON SAV v11.0 - Configuration
# ============================================
# Copier ce fichier vers .env et remplir vos credentials
# Puis securiser : chmod 600 .env

# ============================================
# PostgreSQL Database
# ============================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=oktagon_sav
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password_here
# SSL mode: disable, prefer (default), require, verify-full
POSTGRES_SSL_MODE=prefer

# ============================================
# Anthropic Claude API
# ============================================
# Obtenir une cle sur : https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-VOTRE_CLE_ICI
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# ============================================
# Shopify API (OAuth Client Credentials)
# ============================================
# App custom dans Admin Shopify > Apps > Develop apps
SHOPIFY_STORE=votre-boutique.myshopify.com
SHOPIFY_CLIENT_ID=votre_client_id_ici
SHOPIFY_CLIENT_SECRET=shpss_votre_secret_ici
SHOPIFY_API_VERSION=2025-01

# ============================================
# Gmail Integration
# ============================================
# Utiliser un mot de passe d'application (2FA requis)
# https://myaccount.google.com/apppasswords
# Note : les espaces dans le mot de passe sont normaux (Google les met)
GMAIL_ADDRESS=sav@votre-domaine.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ============================================
# Dashboard Authentication
# ============================================
# Credentials pour acceder au dashboard (port 8888)
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=changez_ce_mot_de_passe_fort

# ============================================
# Telegram Notifications (Optionnel)
# ============================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_USINE_BOT_TOKEN=
TELEGRAM_USINE_CHAT_ID=

# ============================================
# Agent IA
# ============================================
AUTONOMY_LEVEL=2
CONFIDENCE_THRESHOLD=0.90

# ============================================
# Serveur
# ============================================
SERVER_PORT=8888
TEST_MODE=false
LOG_LEVEL=INFO

# ============================================
# Securite
# ============================================
HASH_SALT=changez_ce_salt_unique_ici

# ============================================
# Monitoring Sentry (Optionnel)
# ============================================
# Laisser vide ou "placeholder" pour desactiver en dev
SENTRY_DSN=https://placeholder@sentry.io/placeholder
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
