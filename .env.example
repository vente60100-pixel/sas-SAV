# ============================================
# OKTAGON SAV - Configuration Example
# ============================================
# Copier ce fichier vers .env et remplir vos credentials
# Puis sécuriser : chmod 600 .env

# ============================================
# PostgreSQL Database
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=oktagon_sav
DB_USER=your_db_user
DB_PASSWORD=your_db_password_here

# ============================================
# Anthropic Claude API
# ============================================
# Obtenir une clé sur : https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-VOTRE_CLE_ICI

# ============================================
# Shopify API (OAuth Client Credentials)
# ============================================
# App custom dans Admin Shopify > Apps > Develop apps
SHOPIFY_STORE=votre-boutique.myshopify.com
SHOPIFY_CLIENT_ID=votre_client_id_ici
SHOPIFY_CLIENT_SECRET=shpss_votre_secret_ici

# ============================================
# Gmail Integration
# ============================================
# Utiliser un mot de passe d'application (2FA requis)
# https://myaccount.google.com/apppasswords
GMAIL_USER=sav@votre-domaine.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ============================================
# Dashboard Authentication
# ============================================
# Credentials pour accéder au dashboard (port 8888)
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=changez_ce_mot_de_passe_fort

# ============================================
# Monitoring Sentry (Optionnel)
# ============================================
# Laisser vide ou "placeholder" pour désactiver en dev
SENTRY_DSN=https://placeholder@sentry.io/placeholder
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ============================================
# Application Version
# ============================================
APP_VERSION=10.0
