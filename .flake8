[flake8]
max-line-length = 127
max-complexity = 10
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    env,
    build,
    dist,
    *.egg-info,
    .eggs,
    .pytest_cache,
    .mypy_cache,
    htmlcov

ignore =
    E203,  # whitespace before ':'
    E501,  # line too long (handled by max-line-length)
    W503,  # line break before binary operator
    E402,  # module level import not at top of file

per-file-ignores =
    __init__.py:F401,F403
    tests/*:F401,F811

count = True
statistics = True
show-source = True
